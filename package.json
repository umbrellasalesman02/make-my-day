{
  "name": "make-my-day",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run test -r && vp run build -r",
    "dev": "vp run website#dev",
    "agent-gui:start": "vp run agent-gui#start",
    "agent-gui:remote": "vp run agent-gui#start:remote",
    "deployer:smoke": "vp run deployer#smoke",
    "mvp:smoke": "vp run agent-gui#preflight && vp run deployer#smoke",
    "effect-solutions": "node node_modules/effect-solutions/bin.js",
    "typecheck": "vp run typecheck -r",
    "prepare": "vp config && vp exec effect-language-service patch"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "effect-solutions": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
